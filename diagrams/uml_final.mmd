classDiagram
    %% PawPal+ Final Class Diagram — reflects actual implementation in pawpal_system.py

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +list~str~ special_needs
        +get_summary() str
        +add_special_need(need: str) None
        +remove_special_need(need: str) None
    }

    class Owner {
        +str name
        +int available_minutes
        +str preferred_start_time
        +dict preferences
        +get_time_budget() int
        +update_preferences(key: str, value) None
        +start_time_in_minutes() int
    }

    class Task {
        +str name
        +str category
        +int duration_minutes
        +str priority
        +bool is_recurring
        +str frequency
        +str notes
        +bool completed
        +str start_time
        +str pet_name
        +mark_complete() None
        +create_next_occurrence() Task
        +is_high_priority() bool
        +get_summary() str
        +to_dict() dict
    }

    class Scheduler {
        +Owner owner
        +Pet pet
        +list~Task~ tasks
        +list~dict~ scheduled_plan
        +add_task(task: Task) None
        +remove_task(task_name: str) None
        +complete_task(task_name: str) Task
        +sort_tasks_by_priority() None
        +sort_tasks_by_time() None
        +filter_tasks(completed: bool, pet_name: str) list~Task~
        +get_recurring_tasks() list~Task~
        +detect_conflicts() list~tuple~
        +get_conflict_warnings() list~str~
        +generate_plan() None
        +get_plan_summary() str
        +get_skipped_tasks() list~Task~
    }

    class HelperFunctions {
        <<module>>
        +find_conflicts_across_schedulers(schedulers: list) list~str~
        +_minutes_to_hhmm(total_minutes: int) str
        +_hhmm_to_minutes(hhmm: str) int
        +_find_conflicts(tasks: list) list~tuple~
        +_format_conflict_warning(a: Task, b: Task) str
    }

    Owner "1" --> "1" Pet : owns
    Owner "1" --> "1" Scheduler : drives
    Scheduler "1" *-- "0..*" Task : manages
    Scheduler --> Pet : reads needs of
    Scheduler ..> Task : creates via complete_task()
    HelperFunctions ..> Scheduler : used by
